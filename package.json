{
  "name": "@zerobounce/zero-bounce-sdk",
  "version": "2.1.2",
  "description": "This SDK contains methods for interacting easily with ZeroBounce API. More information about ZeroBounce you can find in the official documentation.",
  "main": "dist/zeroBounceSDK.js",
  "types": "zeroBounceSDK.d.ts",
  "exports": {
    ".": {
      "types": "./zeroBounceSDK.d.ts",
      "import": "./dist/zeroBounceSDK.js",
      "require": "./dist/zeroBounceSDK.js",
      "default": "./dist/zeroBounceSDK.js"
    }
  },
  "files": [
    "dist",
    "zeroBounceSDK.d.ts",
    "README.md"
  ],
  "scripts": {
    "test": "jest && npm run test:types",
    "test:unit": "jest",
    "test:smoke": "node tests/smoke-dist.js",
    "test:coverage": "jest --coverage",
    "build": "webpack --mode=production",
    "prepublishOnly": "npm run build",
    "dts-check": "tsc --noEmit",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "test:real-api": "node tests/real-api-prod.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerobounce/zero-bounce-javascript.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zerobounce/zero-bounce-javascript/issues"
  },
  "homepage": "https://github.com/zerobounce/zero-bounce-javascript#readme",
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "webpack": "^5.78.0",
    "webpack-cli": "^7.0.2",
    "whatwg-fetch": "^3.6.18",
    "typescript": "^6.0.2"
  }
}
